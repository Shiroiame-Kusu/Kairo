<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Kairo.ViewModels"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="Kairo.Components.DashBoard.LanPartyLobbyPage"
             x:DataType="vm:LanPartyLobbyPageViewModel"
             VerticalAlignment="Stretch">
    <Grid Margin="0" RowDefinitions="Auto,*">
        <fa:FAInfoBar Grid.Row="0"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Error"
                    Title="联机房间功能尚未完全实现"
                    Message="此页面目前仅作为界面展示，相关功能暂不可用。"
                    Margin="0,0,0,8" />
        <fa:FANavigationView Grid.Row="1" x:Name="LobbyNavView"
                           PaneDisplayMode="Top"
                           IsSettingsVisible="False"
                           AlwaysShowHeader="False"
                           IsBackButtonVisible="False"
                           SelectionChanged="LobbyNavView_OnSelectionChanged">
            <fa:FANavigationView.MenuItems>
                <fa:FANavigationViewItem x:Name="HostNavItem" Content="创建房间" Tag="host">
                    <fa:FANavigationViewItem.IconSource>
                        <fa:FASymbolIconSource Symbol="Add" />
                    </fa:FANavigationViewItem.IconSource>
                </fa:FANavigationViewItem>
                <fa:FANavigationViewItem Content="加入房间" Tag="join">
                    <fa:FANavigationViewItem.IconSource>
                        <fa:FASymbolIconSource Symbol="People" />
                    </fa:FANavigationViewItem.IconSource>
                </fa:FANavigationViewItem>
            </fa:FANavigationView.MenuItems>
            <ContentControl x:Name="LobbyContentHost" Margin="12" />
        </fa:FANavigationView>
    </Grid>
</UserControl>
