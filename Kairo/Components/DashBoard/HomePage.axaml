<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="clr-namespace:Kairo.ViewModels"
             x:Class="Kairo.Components.DashBoard.HomePage"
             x:DataType="vm:HomePageViewModel">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12" Margin="12">
        <Border Grid.Row="0" CornerRadius="8" Padding="14,10" Background="{DynamicResource LayerFillColorDefaultBrush}">
            <StackPanel Spacing="4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <fa:SymbolIcon Symbol="Home" FontSize="22" />
                    <TextBlock VerticalAlignment="Center" FontSize="24" Text="{Binding WelcomeText}" />
                </StackPanel>
                <TextBlock Text="首页概览与公告" Opacity="0.8" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="auto,*" ColumnSpacing="12">
            <Border Grid.Column="0" CornerRadius="8" Padding="10" Background="{DynamicResource LayerFillColorDefaultBrush}">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="15" ClipToBounds="True"
                                Background="{DynamicResource LayerFillColorAltBrush}">
                            <Image Source="{Binding AvatarImage}" Stretch="UniformToFill" />
                        </Border>
                        <TextBlock Text="当前账号" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding UserNameText}" FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="UID" Opacity="0.75" />
                        <TextBlock Grid.Column="1" Text="{Binding UserIdText}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="状态" Opacity="0.75" />
                        <TextBlock Grid.Column="1" Text="{Binding LoginStatusText}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="邮箱" Opacity="0.75" />
                        <TextBlock Grid.Column="1" Text="{Binding UserEmailText}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="QQ" Opacity="0.75" />
                        <TextBlock Grid.Column="1" Text="{Binding UserQQText}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="注册" Opacity="0.75" />
                        <TextBlock Grid.Column="1" Text="{Binding UserRegTimeText}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" CornerRadius="8" Padding="12" Background="{DynamicResource LayerFillColorDefaultBrush}">
                <ScrollViewer>
                    <TextBlock Text="{Binding Announcement}" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" CornerRadius="8" Padding="12" Background="{DynamicResource LayerFillColorDefaultBrush}">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="12">
                <Border Grid.Column="0" VerticalAlignment="Center" Padding="12" CornerRadius="8"
                        Background="{DynamicResource LayerFillColorAltBrush}">
                    <TextBlock Text="{Binding BandwidthText}" />
                </Border>
                <Border Grid.Column="1" VerticalAlignment="Center" Padding="12" CornerRadius="8"
                        Background="{DynamicResource LayerFillColorAltBrush}">
                    <TextBlock Text="{Binding TrafficText}" />
                </Border>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="签到" Command="{Binding SignCommand}" IsVisible="{Binding SignButtonVisible}" />
                    <Border IsVisible="{Binding SignedBorderVisible}" CornerRadius="6" Padding="8" Background="#33999999">
                        <TextBlock Text="你今天已经签到过啦！" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>